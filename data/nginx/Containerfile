FROM nginx:mainline-alpine-slim

ENV BROTLI_VERSION 1.0.0
ENV ZSTD_VERSION 0.1.1
ENV ACME_VERSION 0.3.1

RUN apk add --no-cache curl \
    && apk add --no-cache --virtual .build-deps \
        gcc \
        libc-dev \
        make \
        openssl-dev \
        pcre2-dev \
        zlib-dev \
        linux-headers \
        bash \
        cargo \
        clang-libclang \
        brotli-dev \
        zstd-dev
RUN set -x \
  && tempDir="$(mktemp -d)" \
  && export HOME=${tempDir} \
  && cd ${tempDir} \
  && curl -LO https://nginx.org/download/nginx-${NGINX_VERSION}.tar.gz \
  && tar xvzf nginx-${NGINX_VERSION}.tar.gz \
  && curl -LO https://github.com/google/ngx_brotli/archive/refs/tags/v${BROTLI_VERSION}rc.tar.gz \
  && tar xvzf v${BROTLI_VERSION}rc.tar.gz \
  && curl -LO https://github.com/tokers/zstd-nginx-module/archive/refs/tags/${ZSTD_VERSION}.tar.gz \
  && tar xvzf ${ZSTD_VERSION}.tar.gz \
  && curl -LO https://github.com/nginx/nginx-acme/releases/download/v${ACME_VERSION}/nginx-acme-${ACME_VERSION}.tar.gz \
  && tar xvzf nginx-acme-${ACME_VERSION}.tar.gz \
  && cd nginx-${NGINX_VERSION} \
  && ./configure \
        --prefix=/etc/nginx \
        --sbin-path=/usr/sbin/nginx \
        --modules-path=/usr/lib/nginx/modules \
        --conf-path=/etc/nginx/nginx.conf \
        --error-log-path=/var/log/nginx/error.log \
        --http-log-path=/var/log/nginx/access.log \
        --pid-path=/run/nginx.pid \
        --lock-path=/run/nginx.lock \
        --http-client-body-temp-path=/var/cache/nginx/client_temp \
        --http-proxy-temp-path=/var/cache/nginx/proxy_temp \
        --http-fastcgi-temp-path=/var/cache/nginx/fastcgi_temp \
        --http-uwsgi-temp-path=/var/cache/nginx/uwsgi_temp \
        --http-scgi-temp-path=/var/cache/nginx/scgi_temp \
        --user=nginx \
        --group=nginx \
        --with-compat \
        --with-file-aio \
        --with-threads \
        --with-http_gzip_static_module \
        --with-http_realip_module \
        --with-http_ssl_module \
        --with-http_stub_status_module \
        --with-http_sub_module \
        --with-http_v2_module \
        --with-http_v3_module \
        --with-stream \
        --with-stream_realip_module \
        --with-stream_ssl_module \
        --with-stream_ssl_preread_module \
        --add-dynamic-module=../ngx_brotli-${BROTLI_VERSION}rc \
        --add-dynamic-module=../zstd-nginx-module-${ZSTD_VERSION} \
        --add-dynamic-module=../nginx-acme-${ACME_VERSION} \
  && make \
  && make modules \
  && make install \
  && cd /etc/nginx \
  && rm -rf conf.d fastcgi* html koi* *.default scgi* uwsgi* win-utf \
  && cd / \
  && rm -rf ${tempDir} \

